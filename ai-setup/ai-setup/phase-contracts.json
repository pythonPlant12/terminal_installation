      "script": "scripts/phases/01-preflight.zsh",
      "inputs": [
        "macos-runtime",
        "network-access"
      ],
      "outputs": [
        "homebrew-ready",
        "git-ready",
        "zsh-ready"
      ],
      "side_effects": [
        "checks-platform",
        "installs-homebrew-if-missing"
      ],
      "must_run_after": [],
      "behavior_markers": [
        "require_macos_supported",
        "require_cmd git",
        "raw.githubusercontent.com/Homebrew/install/HEAD/install.sh"
      ]
    },
    {
