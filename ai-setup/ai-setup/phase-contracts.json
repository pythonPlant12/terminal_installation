      "label": "dependencies",
      "script": "scripts/phases/02-dependencies.zsh",
      "inputs": [
        "Brewfile",
        "network-access",
        "nvm-home"
      ],
      "outputs": [
        "brew-dependencies-ready",
        "node-runtime-ready",
        "bun-runtime-ready"
